# EduBot Service Environment Variables
# Copy to .env and fill in real values

# Primary AI (Gemini via OpenAI-compatible endpoint)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Fallback AI (OpenRouter — used if Gemini fails)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Auth
JWT_SECRET=same_secret_as_go_backend

# Go Backend (for read-only tool calls)
GO_BACKEND_URL=http://backend-go:8080
GO_BACKEND_TIMEOUT=8

# Redis
REDIS_URL=redis://redis:6379/1

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# App
ENV=development
LOG_LEVEL=INFO
SESSION_TTL_SECONDS=1800
MAX_HISTORY_PAIRS=10
GEMINI_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=20
