# ═══════════════════════════════════════════════════════════════════════════
# Eduplexo Production Environment Variables (Local Production Run)
# ═══════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=eduplexo_prod
POSTGRES_USER=eduplexo_app
POSTGRES_PASSWORD=eduplexo_prod_pass_12345

# ─── Application ──────────────────────────────────────────────────────────
JWT_SECRET=eduplexo_jwt_production_secret_32_chars_long
ALLOWED_ORIGINS=https://app.eduplexo.com,https://admin.eduplexo.com,http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=eduplexo_redis_pass_12345

# ─── Domain ──────────────────────────────────────────────────────────────
DOMAIN=localhost

# ─── Google Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyAyy8Iqs8--IHN1SexG7XIqYcR7cvLKz5A
GEMINI_MODEL=gemini-2.5-flash
