PORT=8080
APP_NAME=school

# Replace with a strong random string for any non-local environment.
# Tokens issued under one secret cannot be verified under another.
JWT_SECRET=dev-only-jwt-secret-change-me

# Comma-separated list of origins allowed by the CORS middleware.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Set to "true" in production so the session cookie carries the Secure flag.
COOKIE_SECURE=false
