# Public API base used by the frontend service client.
VITE_API_BASE_URL=/api

# Phase 2: proxy /api/* to the Go backend running on :8080.
VITE_API_PROXY_TARGET=http://localhost:8080

# Phase 2: real backend is up — no mocks needed.
VITE_ENABLE_MOCKS=false

# Public app metadata
VITE_APP_NAME=Eduplexo — School Workspace
VITE_APP_DESCRIPTION=Multi-school SaaS school workspace
