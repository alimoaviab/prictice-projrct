{
  "name": "multi-school-saas",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "shared",
    "school-app",
    "super-admin-app"
  ],
  "scripts": {
    "dev:school": "npm --workspace school-app run dev",
    "dev:super-admin": "npm --workspace super-admin-app run dev",
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "next@*": {
      "postcss": "8.5.10"
    }
  }
}
