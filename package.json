{
  "name": "multi-school-saas",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "shared",
    "school-app",
    "super-admin-app"
  ],
  "scripts": {
    "dev:school": "npm --workspace school-app run dev",
    "dev:super-admin": "npm --workspace super-admin-app run dev",
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "test:settings": "node test-settings.js",
    "test:exams": "node test-exams.js",
    "test:results": "node test-results.js",
    "test:all": "node test-all.js"
  },
  "devDependencies": {
    "@studio-freight/lenis": "^1.0.42",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "school-app": "workspace:*",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "next@*": {
      "postcss": "8.5.10"
    }
  },
  "dependencies": {
    "dequal": "^2.0.3",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.14.0"
  }
}
